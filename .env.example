# Copy to .env and fill in your values

# Admin password — also set in Netlify environment variables
VITE_ADMIN_PASSWORD=change_me

# Supabase public keys — safe for browser, set in Netlify env vars
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key — NEVER expose in browser
# Set ONLY in Netlify environment variables (not in .env committed to git)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudinary — image uploads (public, safe for browser)
VITE_CLOUDINARY_CLOUD_NAME=daympzgxr
VITE_CLOUDINARY_UPLOAD_PRESET=portfolio_unsigned
